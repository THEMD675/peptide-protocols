# pptides.com — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# See docs/SECRETS_INVENTORY.md for full list.

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Push Notifications (required for PWA push)
VITE_VAPID_PUBLIC_KEY=

# Bot Protection (required for auth forms)
VITE_TURNSTILE_SITE_KEY=

# Analytics (optional)
VITE_GA4_ID=

# For local scripts only (get from Supabase Dashboard → Edge Functions → Secrets)
# STRIPE_SECRET_KEY=sk_xxx   → npm run verify-stripe
# CRON_SECRET=xxx            → npm run verify-health
