{
  "name": "peptide-protocols",
  "private": true,
  "version": "1.0.0",
  "description": "أشمل دليل عربي للببتيدات العلاجية",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-sitemap.mjs",
    "build": "vite build && node -e \"const fs=require('fs');const f='dist/registerSW.js';fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(\\\"{ scope: '/' }\\\",\\\"{ scope: '/', updateViaCache: 'none' }\\\"))\" && node scripts/prerender.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "verify-stripe": "node scripts/verify-stripe.js",
    "verify-health": "node -e \"const s=process.env.CRON_SECRET;if(!s){console.error('Set CRON_SECRET (from Supabase Dashboard → Edge Functions → Secrets). See docs/SECRETS_INVENTORY.md');process.exit(1)}fetch('https://rxxzphwojutewvbfzgqd.supabase.co/functions/v1/health-check',{headers:{'x-cron-secret':s}}).then(r=>r.json()).then(d=>console.log(JSON.stringify(d,null,2))).catch(e=>{console.error(e);process.exit(1)})\"",
    "verify": "bash scripts/run-verification.sh",
    "verify-stripe:remote": "node -e \"const s=process.env.CRON_SECRET;if(!s){console.error('Set CRON_SECRET');process.exit(1)}fetch('https://rxxzphwojutewvbfzgqd.supabase.co/functions/v1/verify-stripe',{headers:{'x-cron-secret':s}}).then(r=>r.json()).then(d=>console.log(JSON.stringify(d,null,2))).catch(e=>{console.error(e);process.exit(1)})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "predeploy": "npm run type-check && npm run build",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel"
  },
  "dependencies": {
    "@sentry/react": "^10.43.0",
    "@supabase/supabase-js": "^2.97.0",
    "@vercel/analytics": "^2.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "focus-trap-react": "^12.0.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-joyride": "^2.9.3",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.1.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@sentry/vite-plugin": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vercel/edge": "^1.2.2",
    "@vercel/node": "^5.6.15",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "puppeteer": "^24.38.0",
    "stripe": "^17.4.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tar": "^7.5.11",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vercel": "^50.1.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-core": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  }
}
